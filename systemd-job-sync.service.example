[Unit]
Description=Albus Barks Bright Data LinkedIn Job Sync
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
EnvironmentFile=-/etc/default/albus-barks
WorkingDirectory=/home/albus/albus-barks
ExecStart=/home/albus/albus-barks/.venv/bin/python -m background.job_sync
StandardOutput=journal
StandardError=journal
User=albus
